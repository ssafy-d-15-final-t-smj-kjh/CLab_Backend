<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.clab.member.dao.MemberMapper">

    <resultMap id="memberMap" type="com.clab.member.dto.MemberDto">
        <id property="userId" column="user_id"/>
        <result property="id" column="id"/>
        <result property="password" column="password"/>
        <result property="email" column="email"/>
        <result property="image" column="image"/>
    </resultMap>

    <!-- 전체 조회 -->
    <select id="findAll" resultMap="memberMap">
        SELECT
            user_id,
            id,
            password,
            email,
            image
        FROM member
    </select>

    <!-- 단건 조회 -->
    <select id="findById"
            parameterType="int"
            resultMap="memberMap">
        SELECT
            user_id,
            id,
            password,
            email,
            image
        FROM member
        WHERE user_id = #{id}
    </select>

    <!-- 등록 -->
    <insert id="insert" parameterType="com.clab.member.dto.MemberDto">

        INSERT INTO member
        (
            id,
            password,
            email,
            image
        )
        VALUES
        (
            #{id},
            #{password},
            #{email},
            #{image}
        )

    </insert>

    <!-- 수정 -->
    <update id="update" parameterType="com.clab.member.dto.MemberDto">

        UPDATE member
        SET
            id = #{id},
            password = #{password},
            email = #{email},
            image = #{image}
        WHERE user_id = #{userId}

    </update>

    <!-- 삭제 -->
    <delete id="delete" parameterType="int">

        DELETE FROM member
        WHERE user_id = #{id}

    </delete>

</mapper>